# === OpenAI ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini
# If behind a corporate proxy or using Azure OpenAI, set this; otherwise leave blank.
OPENAI_BASE_URL=
# Optional PEM bundle for corporate TLS inspection / private CAs.
OPENAI_CA_BUNDLE=
# Use the OS trust store instead of HTTPX's bundled CA set.
OPENAI_USE_SYSTEM_CERT_STORE=true

# === SQL Server — Per-database connection strings (used by registry/connection.yaml) ===
# Full pyodbc connection string for each named database
PRIME_DB_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-prime-server;DATABASE=PRIME;Trusted_Connection=yes;
SCS_DB_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-scs-server;DATABASE=PBI;Trusted_Connection=yes;

# === SQL Server — Legacy single-DB settings (fallback / default connection) ===
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_SERVER=your-server-name
DB_DATABASE=your-database-name
# Leave DB_USERNAME blank for Windows Authentication (Trusted_Connection=yes)
DB_USERNAME=
DB_PASSWORD=
DB_TIMEOUT=30

# === App Settings ===
DAILY_REQUEST_LIMIT=10
MAX_EXPORT_ROWS=100000
FISCAL_YEAR_START_MONTH=1

# === Hardcoded Test User (MVP) ===
TEST_USER_ID=test_user
TEST_USER_NAME=Test User
TEST_USER_FACILITIES=["ALL"]
